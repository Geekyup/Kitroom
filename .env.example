DEBUG=true
PROJECT_NAME=DrumKit Service

# DATABASE_URL и REDIS_URL переопределяются в docker-compose.yml
# для локального запуска без Docker используй localhost
DATABASE_URL=postgresql+asyncpg://postgres:12345@localhost:5432/Drum
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=замени-на-случайную-строку-минимум-32-символа
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

SESSION_SECRET_KEY=замени-на-случайную-строку

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
VERIFICATION_CODE_EXPIRE_MINUTES=15
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15

UPLOADS_STORAGE_ROOT=./storage/uploads
PUBLIC_STORAGE_ROOT=./storage/public

MAX_ZIP_SIZE_MB=500
MAX_FILES_PER_KIT=2000

# --- Docker Compose: параметры контейнера postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345
POSTGRES_DB=Drum

# --- Docker Compose: адрес API для фронтенда (собирается в билд-тайм) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
